GEMINI_API_KEY=your_gemini_api_key_here

# Resend API Key for sending emails (Newsletter)
RESEND_API_KEY=re_your_resend_api_key_here
# The email address that will receive the new subscriber notifications
EMAIL_TO=your.email@example.com
# The domain used for the sender address (e.g. yourdomain.com to send from no-reply@yourdomain.com)
EMAIL_DOMAIN=example.com
